---
interface Props {
  isDark: boolean;
}

const { isDark } = Astro.props;
---

<html lang="en" class={isDark ? "dark" : ""}>
  <head>
    <meta charset="utf-8" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <meta name="viewport" content="width=device-width" />
    <title>Dimitar Dimov</title>
    <meta
      name="desciption"
      content="Backend architect at Dreamshot, where we create online games and innovative products."
    />
    <meta property="og:title" content="Dimitar Dimov" />
    <meta
      property="og:description"
      content="Backend architect at Dreamshot, where we create online games and innovative products."
    />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1024" />
    <meta property="og:image:height" content="1066" />
    <meta property="og:image" content="https://ddimov.dev/image.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content="Dimitar Dimov" />
    <meta
      property="twitter:description"
      content="Backend architect at Dreamshot, where we create online games and innovative products."
    />
    <meta property="twitter:image:type" content="image/png" />
    <meta property="twitter:image:width" content="1024" />
    <meta property="twitter:image:height" content="1066" />
    <meta property="twitter:image" content="https://ddimov.dev/image.png" />
  </head>
  <body class="bg-background text-foreground">
    <div class="flex flex-col min-h-screen">
      <slot />
    </div>
  </body>
</html>
